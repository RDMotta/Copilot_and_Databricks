# ════════════════════════════════════════════════════════════════════
# Credenciais Databricks
# Configure os valores reais nos Codespaces Secrets (nunca commite este arquivo!)
# github.com → Settings → Codespaces → Secrets
# ════════════════════════════════════════════════════════════════════

# URL do seu workspace Databricks Community Edition
# Exemplo: https://community.cloud.databricks.com
DATABRICKS_HOST=https://community.cloud.databricks.com

# Personal Access Token gerado em Settings → Developer → Access Tokens
DATABRICKS_TOKEN=

# ID do cluster criado para o treinamento
# Encontre em: Compute → seu cluster → JSON → cluster_id
DATABRICKS_CLUSTER_ID=

# ── Paths do DBFS (não altere sem necessidade) ────────────────────
DBFS_TRAINING_ROOT=/FileStore/training
DBFS_RAW_PATH=/FileStore/training/raw
DBFS_BRONZE_PATH=/FileStore/training/ecommerce_lakehouse/bronze
DBFS_SILVER_PATH=/FileStore/training/ecommerce_lakehouse/silver
DBFS_GOLD_PATH=/FileStore/training/ecommerce_lakehouse/gold

# ── Configurações PySpark local ───────────────────────────────────
SPARK_LOCAL_IP=127.0.0.1
PYSPARK_PYTHON=/usr/local/bin/python3
